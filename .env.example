# Next.js Environment
NEXT_PUBLIC_SITE_NAME=Bayan Kuaför Salonu
NEXT_PUBLIC_SITE_URL=https://salonnamehere.com
NODE_ENV=production

# Google Analytics
NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXX

# APIs
NEXT_PUBLIC_API_BASE_URL=https://api.salonnamehere.com
DATABASE_URL=postgresql://user:password@db.host:5432/blog_db

# Blog API
NEXT_PUBLIC_BLOG_API=https://api.salonnamehere.com/blog

# DigitalOcean Spaces (CDN)
NEXT_PUBLIC_CDN_URL=https://cdn.salonnamehere.com
DO_SPACES_BUCKET=salon-content
DO_SPACES_REGION=fra
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key

# Email Service
SENDGRID_API_KEY=your-sendgrid-key
CONTACT_EMAIL=info@salonnamehere.com

# Google Services
GOOGLE_SEARCH_CONSOLE_VERIFICATION=your-verification-code

# Social Media
FACEBOOK_PIXEL_ID=your-facebook-pixel-id
INSTAGRAM_HANDLE=your-instagram
WHATSAPP_NUMBER=+90XXXXXXXXX

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Feature Flags
ENABLE_BLOG=true
ENABLE_COMMENTS=false
ENABLE_NEWSLETTER=true

# Security
SESSION_SECRET=your-session-secret-key-min-32-chars-long
CSRF_TOKEN_SECRET=your-csrf-secret
